# Copy this file to `.env` and fill in your real API key.
# Never commit the real `.env` file.

# Required: your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
# Optional overrides (defaults shown)
SAFEBANK_MAIN_MODEL=claude-sonnet-5
# Claude 3.7 Sonnet has been retired; pinned to the closest available
# equivalent, a previous-generation Sonnet snapshot.
SAFEBANK_SUBAGENT_MODEL=claude-sonnet-4-5-20250929
SAFEBANK_REQUEST_TIMEOUT_SECONDS=30
SAFEBANK_MAX_RETRIES=3
SAFEBANK_RETRY_BACKOFF_BASE_SECONDS=1
SAFEBANK_MAX_AGENT_STEPS=6
SAFEBANK_SUMMARIZE_AFTER_TURNS=10
SAFEBANK_MAIN_MAX_TOKENS=1024
SAFEBANK_SUBAGENT_MAX_TOKENS=1024
SAFEBANK_ESCALATION_STORE=escalations.jsonl
